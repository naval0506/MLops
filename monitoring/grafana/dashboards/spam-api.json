{
  "title": "Spam Detector API",
  "uid": "spam-api",
  "schemaVersion": 38,
  "panels": [
    {
      "type": "stat",
      "title": "API Up",
      "gridPos": {"x":0,"y":0,"w":4,"h":4},
      "targets": [{"expr": "spam_api_up", "datasource": "Prometheus"}],
      "options": {"colorMode": "background"}
    },
    {
      "type": "timeseries",
      "title": "Requêtes /predict",
      "gridPos": {"x":4,"y":0,"w":20,"h":8},
      "targets": [{"expr": "rate(spam_api_up[5m])", "legendFormat": "req/s", "datasource": "Prometheus"}]
    }
  ],
  "time": {"from": "now-1h","to": "now"},
  "refresh": "30s"
}
